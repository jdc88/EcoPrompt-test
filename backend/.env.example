# Copy to .env in this folder. DATABASE_URL is optional (API works without DB).

# DATABASE_URL=postgresql://user:pass@localhost:5432/ecoprompt

# Ollama (Qwen2.5 recommended) — skeleton extract + reviser
# OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b

# HumanDelta semantic retrieval (style examples for reviser)
# HD_KEY=your_humandelta_api_key

# CORS for the Next.js app (comma-separated)
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
